{
  "problemMatcher": [
    {
      "owner": "dotnet",
      "pattern": [
        {
          "regexp": "^(.+)\\((\\d+),(\\d+)\\):\\s+(warning|error)\\s+([A-Za-z0-9]+):\\s+(.+?)\\s+\\[.+\\]$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      ]
    }
  ]
}
