<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Client.Core.Controls.Timeline"
             Height="32">
  <Panel>
    <Border x:Name="TrackBar"
            Background="#20808080"
            CornerRadius="4" />
    <Canvas x:Name="SpanCanvas"
            ClipToBounds="True" />
    <Canvas x:Name="MarkerCanvas" />
    <Border x:Name="Playhead"
            Width="2"
            Background="#FFFFFF"
            HorizontalAlignment="Left"
            IsHitTestVisible="True"
            Cursor="Hand" />
  </Panel>
</UserControl>
