<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Client.Core.Controls.CameraGrid">
  <ItemsControl x:Name="GridItems"
                ItemsSource="{Binding Cameras}">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate>
        <UniformGrid x:Name="GridPanel" Columns="3" />
      </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
      <DataTemplate>
        <Border Margin="4"
                CornerRadius="8"
                Background="#20808080"
                BorderBrush="#40808080"
                BorderThickness="1"
                Padding="8"
                Cursor="Hand">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding Name}"
                       FontWeight="Medium"
                       FontSize="14" />
            <TextBlock Text="{Binding Status}"
                       FontSize="12"
                       Opacity="0.7" />
          </StackPanel>
        </Border>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
