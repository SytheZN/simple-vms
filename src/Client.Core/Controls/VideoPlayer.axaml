<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="using:IconPacks.Avalonia.PhosphorIcons"
             x:Class="Client.Core.Controls.VideoPlayer">
  <Panel Background="{DynamicResource SurfaceSunkenBrush}">
    <!-- Decoded frame target (WriteableBitmap or GPU interop surface) -->
    <Image x:Name="FrameImage"
           Stretch="Uniform"
           IsVisible="False" />
    <!-- No-video placeholder -->
    <StackPanel x:Name="Placeholder"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <icon:PackIconPhosphorIcons Kind="VideoCamera"
                                  Width="{DynamicResource IconXl}"
                                  Height="{DynamicResource IconXl}"
                                  Foreground="{DynamicResource TextMutedBrush}"
                                  HorizontalAlignment="Center" />
      <TextBlock Text="No video"
                 Classes="text-muted"
                 FontSize="{DynamicResource TextSm}"
                 HorizontalAlignment="Center" />
    </StackPanel>
    <!-- Motion overlay -->
    <Canvas x:Name="MotionOverlay"
            IsVisible="False"
            IsHitTestVisible="False" />
  </Panel>
</UserControl>
