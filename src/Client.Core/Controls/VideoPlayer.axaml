<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Client.Core.Controls"
             x:Class="Client.Core.Controls.VideoPlayer">
  <Panel Background="{DynamicResource SurfaceSunkenBrush}">
    <controls:VideoSurface x:Name="VideoSurface" />
    <StackPanel x:Name="Placeholder"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <controls:PhosphorIcon Kind="VideoCamera"
                                  Width="{DynamicResource IconXl}"
                                  Height="{DynamicResource IconXl}"
                                  Foreground="{DynamicResource TextMutedBrush}"
                                  HorizontalAlignment="Center" />
      <TextBlock Text="No video"
                 Classes="text-muted"
                 FontSize="{DynamicResource TextSm}"
                 HorizontalAlignment="Center" />
    </StackPanel>
    <Canvas x:Name="MotionOverlay"
            IsVisible="False"
            IsHitTestVisible="False" />
  </Panel>
</UserControl>
