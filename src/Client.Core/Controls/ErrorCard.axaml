<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Client.Core.Controls"
             x:Class="Client.Core.Controls.ErrorCard">
  <Border x:Name="Root"
          Background="{DynamicResource DangerMutedBrush}"
          BorderBrush="{DynamicResource DangerBrush}"
          BorderThickness="{DynamicResource BorderWidth}"
          CornerRadius="{DynamicResource RadiusMd}"
          Padding="12"
          IsVisible="False">
    <StackPanel Spacing="8">
      <!-- Message row -->
      <DockPanel>
        <controls:PhosphorIcon Kind="XCircle"
                                    DockPanel.Dock="Left"
                                    Width="{DynamicResource IconMd}"
                                    Height="{DynamicResource IconMd}"
                                    Foreground="{DynamicResource DangerBrush}"
                                    VerticalAlignment="Top"
                                    Margin="0 2 8 0" />
        <TextBlock x:Name="MessageLabel"
                   Foreground="{DynamicResource DangerBrush}"
                   FontSize="{DynamicResource TextSm}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
      </DockPanel>

      <!-- Debug tag + copy -->
      <StackPanel x:Name="TagRow" IsVisible="False"
                  Orientation="Horizontal"
                  Spacing="4"
                  HorizontalAlignment="Right">
        <TextBlock x:Name="TagLabel"
                   FontSize="{DynamicResource TextXs}"
                   Foreground="{DynamicResource TextMutedBrush}"
                   VerticalAlignment="Center" />
        <Button x:Name="CopyButton"
                Classes="btn btn-ghost"
                Padding="2"
                ToolTip.Tip="Copy error details">
          <controls:PhosphorIcon Kind="Copy"
                                      Width="{DynamicResource TextXs}"
                                      Height="{DynamicResource TextXs}"
                                      Foreground="{DynamicResource TextMutedBrush}" />
        </Button>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
