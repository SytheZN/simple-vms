<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Client.Desktop.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Client.Core/Themes/AppTheme.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
  <Application.Styles>
    <StyleInclude Source="avares://Client.Core/Themes/ControlTemplates.axaml" />
    <StyleInclude Source="avares://Client.Core/Themes/ControlStyles.axaml" />
  </Application.Styles>
</Application>
